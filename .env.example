# =============================================================================
# Vercel (Production)
# =============================================================================
# API keys are NOT read from this file on Vercel. Add them in the dashboard so
# they "appear" there and inject at build time:
#
#   Vercel → your project → Settings → Environment Variables
#   - Add each REACT_APP_* you use (names must match exactly).
#   - Environment: Production (and Preview if you want previews to work).
#   - Redeploy after saving (Deployments → … → Redeploy), or push a new commit.
#
# Optional: import names quickly — Vercel → Env Vars → "Add" → paste KEY=value
# lines (you can paste from a local .env; values stay only in Vercel).
#
# Browser-visible keys use the REACT_APP_ prefix (embedded in the JS bundle).
# TWITCH_* / setupProxy only apply to `npm start`; for IGDB in production set
# REACT_APP_IGDB_API_BASE to a server that proxies IGDB (see comment below).
# =============================================================================

# --- Steam Web API (Store catalog: names, images, descriptions, Metacritic) ---
# Create a key: https://steamcommunity.com/dev/apikey
REACT_APP_STEAM_WEB_API_KEY=your_steam_web_api_key_here
# If you also use RAWG, set this to use Steam as the catalog instead
# REACT_APP_PREFER_STEAM=true
# Production: if Store API is blocked by CORS, point to your proxy that mirrors store.steampowered.com
# REACT_APP_STEAM_STORE_PROXY=https://your-host.example.com

# --- RAWG (one key, works in browser + production) ---
# https://rawg.io/apidocs — create account → API key
REACT_APP_RAWG_API_KEY=your_rawg_api_key_here

# --- GameSpot (browser JSONP; optional fallback) ---
REACT_APP_GAMESPOT_API_KEY=your_gamespot_api_key_here

# --- IGDB via Twitch (optional; needs dev proxy in npm start) ---
# 1. Create a Twitch Developer application: https://dev.twitch.tv/console/apps
# 2. Copy Client ID and generate a Client Secret (OAuth client credentials).
# 3. Use TWITCH_* without REACT_APP_ so the secret is NOT embedded in the JS bundle.
#    The dev server proxy (src/setupProxy.js) reads these and calls IGDB for you.
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Turn on IGDB in the app (list + search + details use gamesService).
REACT_APP_USE_IGDB=true

# Optional: production / custom backend that proxies IGDB the same way as /api/igdb
# REACT_APP_IGDB_API_BASE=https://your-server.example.com/v4
